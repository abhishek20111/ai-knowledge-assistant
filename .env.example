# ─── Enterprise AI Knowledge Assistant — Environment Configuration ─────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Ollama (Local LLM) ───────────────────────────────────────────────────────
# URL of your Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# LLM used for answer generation and query expansion
# Options: qwen2.5:7b | qwen2.5:14b | llama3.2:3b
LLM_MODEL=qwen2.5:7b

# Embedding model (must be pulled: ollama pull nomic-embed-text)
EMBED_MODEL=nomic-embed-text

# ─── JWT Authentication ────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random secret in production!
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=enterprise-rag-super-secret-key-change-in-production

JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ─── RAG Configuration ────────────────────────────────────────────────────────
# How many chunks to retrieve initially (before reranking)
RETRIEVAL_K=20

# How many chunks to send to LLM after reranking
RERANK_TOP_K=5

# Number of alternative queries to generate for multi-query retrieval
MULTI_QUERY_COUNT=3

# Number of previous conversation turns to include as memory
MEMORY_WINDOW=5

# Chunking strategy
PARENT_CHUNK_SIZE=1024   # tokens per parent chunk (for context)
CHILD_CHUNK_SIZE=256     # tokens per child chunk (for indexing)
CHUNK_OVERLAP=50         # overlap between consecutive chunks

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Maximum allowed file size in megabytes
MAX_FILE_SIZE_MB=50
