# ─── Virtual Environment ────────────────────────────────────────────────────
# Never commit - huge (500MB+), machine-specific, regenerated by install.bat
venv/
.venv/
env/

# ─── Python Cache ───────────────────────────────────────────────────────────
# Auto-generated bytecode - never commit
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.pyd
.Python
*.egg-info/
dist/
build/

# ─── Data / Runtime Directories ─────────────────────────────────────────────
# These are created automatically when the app runs

# ChromaDB vector store - contains binary HNSW index files, rebuilt from uploads
chroma_db/

# User uploaded documents - user-specific, could be large/sensitive
uploads/

# Session state files - user-specific UI state
sessions/

# BM25 keyword index - auto-rebuilt from ChromaDB on startup
bm25_index.pkl

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite DB - created automatically on first run
*.db
*.sqlite
*.sqlite3

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Environment / Secrets ──────────────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ─── IDE & Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ─── EasyOCR Model Cache ────────────────────────────────────────────────────
# Downloaded on first image upload (~1.5 GB) - not needed in repo
.EasyOCR/

# ─── Testing ────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
